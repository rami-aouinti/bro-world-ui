{
  "ci": {
    "collect": {
      "url": ["http://127.0.0.1:3000/"],
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 3000",
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500,
            "aggregationMethod": "optimistic"
          }
        ],
        "total-blocking-time": [
          "error",
          {
            "maxNumericValue": 200,
            "aggregationMethod": "optimistic"
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
